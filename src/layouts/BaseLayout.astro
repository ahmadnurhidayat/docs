---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import FloatingToolbar from '../components/FloatingToolbar.astro';
import ReadingProgressBar from '../components/ReadingProgressBar.astro';
import '../styles/global.css';
import '../styles/sidebar.css';
import '../styles/markdown.css';

interface Props {
  title: string;
  description?: string;
  slug?: string;
  isCV?: boolean;
  isWelcome?: boolean;
}

const { title, description, slug, isCV = false, isWelcome = false } = Astro.props;
const pageTitle = title ? `${title} — docs` : 'docs';
const pageDesc = description ?? 'Engineering runbooks, cheat sheets, and lab notes.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Build nav tree for sidebar
const allEntries = await getCollection('docs');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonicalURL} />

  <!-- OpenGraph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="docs" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Theme script (inline to prevent flash) -->
  <script is:inline>
    const theme = localStorage.getItem('theme');
    if (theme === 'dark') {
      document.documentElement.classList.add('dark-mode');
    }
  </script>
</head>

<body>
  <ReadingProgressBar />

  <div class="app-container">
    <Sidebar entries={allEntries} currentSlug={slug} />
    
    <div class="sidebar-resizer" id="sidebar-resizer"></div>

    <main class="main-content">
      <Header isWelcome={isWelcome} slug={slug} />
      
      <article class="content-body">
        <slot />
      </article>
    </main>
  </div>

  <FloatingToolbar />
  
  <button id="back-to-top" title="Back to top" aria-label="Scroll back to top">
    <i class="fa-solid fa-arrow-up"></i>
  </button>

  <script src="../scripts/theme.ts"></script>
  <script src="../scripts/toolbar.ts"></script>
  <script src="../scripts/sidebar-resize.ts"></script>
  <script src="../scripts/reading-progress.ts"></script>

  <!-- Mermaid: render ```mermaid code blocks client-side.
       Shiki syntax-highlights them into <pre data-language="mermaid"><code> blocks.
       This script strips the HTML, recovers the raw diagram source, and replaces
       each block with a rendered SVG diagram. -->
  <script type="module" is:inline>
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

    mermaid.initialize({
      startOnLoad: false,
      theme: document.documentElement.classList.contains('dark-mode') ? 'dark' : 'default',
      securityLevel: 'loose',
    });

    function renderMermaidBlocks() {
      // Shiki outputs: <pre ... data-language="mermaid"><code>...</code></pre>
      const blocks = document.querySelectorAll('pre[data-language="mermaid"]');

      blocks.forEach(async (pre, i) => {
        const code = pre.querySelector('code');
        if (!code) return;

        // Strip all HTML tags (Shiki wraps each token in <span>) to get raw text
        const raw = code.innerHTML
          .replace(/<[^>]+>/g, '')          // remove all HTML tags
          .replace(/&lt;/g, '<')
          .replace(/&gt;/g, '>')
          .replace(/&amp;/g, '&')
          .replace(/&#39;/g, "'")
          .replace(/&quot;/g, '"')
          .trim();

        if (!raw) return;

        try {
          const id = `mermaid-diagram-${i}`;
          const { svg } = await mermaid.render(id, raw);

          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-diagram';
          wrapper.innerHTML = svg;
          pre.replaceWith(wrapper);
        } catch (err) {
          console.warn('[mermaid] Failed to render diagram:', err);
        }
      });
    }

    // Re-render when theme changes (dark ↔ light)
    function reinitOnThemeChange() {
      const observer = new MutationObserver(() => {
        const isDark = document.documentElement.classList.contains('dark-mode');
        mermaid.initialize({
          startOnLoad: false,
          theme: isDark ? 'dark' : 'default',
          securityLevel: 'loose',
        });
        // Re-render only if diagrams are already replaced (they won't be <pre> anymore)
        document.querySelectorAll('.mermaid-diagram').forEach(el => el.remove());
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }

    renderMermaidBlocks();
    reinitOnThemeChange();
  </script>
</body>
</html>

<style is:global>
  .app-container {
    display: flex;
    flex: 1;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    background-color: var(--canvas);
    min-width: 0;
    transition: background-color var(--transition-speed);
  }

  .content-body {
    flex: 1;
    overflow-y: auto;
    padding: var(--spacing-section) var(--spacing-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Content body scrollbar (MongoDB style) */
  .content-body::-webkit-scrollbar {
    width: 8px;
  }

  .content-body::-webkit-scrollbar-track {
    background: var(--surface);
    border-radius: 0;
  }

  .content-body::-webkit-scrollbar-thumb {
    background: var(--hairline-strong);
    border-radius: var(--rounded-full);
    border: 2px solid var(--surface);
    min-height: 40px;
  }

  .content-body::-webkit-scrollbar-thumb:hover {
    background: var(--brand-green);
  }

  @media (max-width: 992px) {
    .content-body {
      padding: var(--spacing-section) var(--spacing-lg);
    }
  }

  @media (max-width: 768px) {
    .content-body {
      padding: var(--spacing-xl) var(--spacing-lg);
    }
  }
</style>
