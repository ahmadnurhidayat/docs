---
import type { NavNode } from '../utils/nav-tree';

interface Props {
  prev: NavNode | null;
  next: NavNode | null;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <div class="doc-navigation">
    {prev && (
      <a href={`/docs/${prev.slug}`} class="nav-btn">
        <i class="fa-solid fa-arrow-left"></i>
        <div class="nav-btn-info">
          <span class="nav-label">Previous</span>
          <span class="nav-title">{prev.title || prev.name}</span>
        </div>
      </a>
    )}

    <div class="nav-spacer"></div>

    {next && (
      <a href={`/docs/${next.slug}`} class="nav-btn nav-btn-next">
        <div class="nav-btn-info">
          <span class="nav-label">Next</span>
          <span class="nav-title">{next.title || next.name}</span>
        </div>
        <i class="fa-solid fa-arrow-right"></i>
      </a>
    )}
  </div>
)}

<style>
  .doc-navigation {
    margin-top: 4rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-width: var(--reading-max-width);
    gap: 1.5rem;
  }

  .nav-spacer {
    flex: 1;
  }

  .nav-btn {
    flex: 1;
    max-width: 48%;
    background-color: transparent;
    border: 1px solid var(--border-color);
    padding: 1rem 1.25rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .nav-btn:hover {
    border-color: var(--accent);
    background-color: var(--bg-hover);
  }

  .nav-btn-next {
    text-align: right;
    justify-content: flex-end;
  }

  .nav-btn-info {
    display: flex;
    flex-direction: column;
  }

  .nav-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .nav-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    margin-top: 0.2rem;
  }

  @media (max-width: 768px) {
    .doc-navigation {
      flex-direction: column;
      gap: 0.75rem;
    }

    .nav-btn {
      max-width: 100%;
    }

    .nav-spacer {
      display: none;
    }
  }
</style>
