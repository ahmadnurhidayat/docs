{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "docs",
    "compatibility_date": "2025-07-01",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "routes": [
        {
            "pattern": "docs.beyondyou.my.id",
            "custom_domain": true
        }
    ],
    "assets": {
        "directory": "./dist",
        "not_found_handling": "404-page"
    },
    "observability": {
        "enabled": true
    },
    "upload_source_maps": true
}